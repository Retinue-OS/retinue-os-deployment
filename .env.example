# retinue-deployment — copy to .env and fill in.
#
# Only the variables this deployment adds or constrains are documented here.
# For everything else see the framework's .env.example (retinue/.env.example);
# this deployment does not need most of it, because it runs no messaging
# gateways.

# --- Public edge ---------------------------------------------------------
# The hostname in docker-compose.override.yml must match this.
PUBLIC_HOST=aros.example.com

# Basic auth for the dashboard, as user:hashed-password (htpasswd -nB).
# Escape every $ as $$ for Compose.
TRAEFIK_BASIC_AUTH_USERS=user:$$apr1$$replace$$withyourownhash

# Let's Encrypt registration address.
ACME_EMAIL=you@example.com

# --- GitHub --------------------------------------------------------------
# Aros reads issues/PRs/discussions and opens owner-action issues.
#
# SCOPE THIS NARROWLY. A fine-grained personal access token limited to the
# retinue-os organization, with:
#     Contents: read/write        (chamber commits: log.md, projects/, docs/)
#     Issues: read/write          (owner-action issues, triage)
#     Pull requests: read
#     Pages: read                 (verify the dashboard actually deployed —
#                                  publishing itself needs only Contents, since
#                                  branch pushes trigger the Pages build)
#     Metadata: read
#
# Do NOT grant Administration, Members, or org-level write. Creating repos,
# changing membership and transferring repos are owner actions — see the
# chamber's GUARDRAILS.md §7. Aros is designed to hand those to a human, and a
# token that can't do them keeps the design honest under prompt injection.
#
# Do NOT grant Workflows write either, and not because of §7: workflow files
# execute on Actions runners holding the repository's GITHUB_TOKEN and secrets,
# so the ability to edit them is an arbitrary-code-with-credentials channel —
# the classic escalation path for compromised automation. It also matches the
# framework's own tiering: dashboard data is operational output (direct push),
# but a workflow change is a change to how the system works — PR territory.
# If Aros needs a workflow changed, he drafts it and opens an owner-action
# issue; the owner commits it.
GITHUB_TOKEN=github_pat_replace_me

# --- Outbound social -----------------------------------------------------
# Send-control for a future social-gateway sidecar, identity-keyed like every
# other channel (email/Signal/WhatsApp/Telegram):
#
#   verify  — queue every post for approval on the dashboard's /sends page
#   trust   — send directly only when the caller asserts --user-approved
#   allow   — send directly
#
# Aros's own accounts run `allow`: they are created by the owner (accounts need
# legal personhood), labeled as an AI agent in the bio, and handed over — from
# then on he publishes in his own name without per-post approval. The autonomy
# is identity-shaped: it covers his accounts and nobody else's. The owner's
# identities are not configured here at all — Aros never speaks as the owner.
#
# Until the gateway exists, platform tokens live in this file — an acknowledged
# deviation from the framework's credential-isolation rule, bounded because the
# identity at stake is Aros's own labeled account, not the owner's.
SOCIAL_SEND_POLICY=allow

# --- Model access --------------------------------------------------------
# See the framework's .env.example. Aros is a low-volume agent — he wakes every
# 30 minutes and usually does nothing — so the cheaper tier is fine.
# ANTHROPIC_API_KEY=

# --- Updater -------------------------------------------------------------
# Token for the updater sidecar's POST /update. Unset means reject all.
# UPDATER_TOKEN=
