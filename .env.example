# retinue-deployment — copy to .env and fill in.
#
# Only the variables this deployment adds or constrains are documented here.
# For everything else see the framework's .env.example (retinue/.env.example);
# this deployment does not need most of it, because it runs no messaging
# gateways.

# --- Public edge ---------------------------------------------------------
# The hostname in docker-compose.override.yml must match this.
PUBLIC_HOST=aros.example.com

# Basic auth for the dashboard, as user:hashed-password (htpasswd -nB).
# Escape every $ as $$ for Compose.
TRAEFIK_BASIC_AUTH_USERS=user:$$apr1$$replace$$withyourownhash

# Let's Encrypt registration address.
ACME_EMAIL=you@example.com

# --- GitHub --------------------------------------------------------------
# Aros reads issues/PRs/discussions and opens owner-action issues.
#
# SCOPE THIS NARROWLY. A fine-grained personal access token limited to the
# retinue-os organization, with:
#     Contents: read/write        (chamber commits: log.md, projects/, docs/)
#     Issues: read/write          (owner-action issues, triage)
#     Pull requests: read
#     Metadata: read
#
# Do NOT grant Administration, Members, or org-level write. Creating repos,
# changing membership and transferring repos are owner actions — see the
# chamber's GUARDRAILS.md §7. Aros is designed to hand those to a human, and a
# token that can't do them keeps the design honest under prompt injection.
GITHUB_TOKEN=github_pat_replace_me

# --- Outbound social -----------------------------------------------------
# Reserved for a future social-gateway sidecar, following the same identity-keyed
# send-control model as email/Signal/WhatsApp/Telegram.
#
#   verify  — queue every post for approval on the dashboard's /sends page
#   trust   — send directly only when the caller asserts --user-approved
#   allow   — send directly
#
# Leave this at `verify`. Aros is a brand-new agent speaking as the project in
# public; there is no version of "he posts unilaterally" that is a good idea
# yet. An agent may never approve its own send.
SOCIAL_SEND_POLICY=verify

# --- Model access --------------------------------------------------------
# See the framework's .env.example. Aros is a low-volume agent — he wakes every
# 30 minutes and usually does nothing — so the cheaper tier is fine.
# ANTHROPIC_API_KEY=

# --- Updater -------------------------------------------------------------
# Token for the updater sidecar's POST /update. Unset means reject all.
# UPDATER_TOKEN=
